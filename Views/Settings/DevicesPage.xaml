<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="AutoOS.Views.Settings.DevicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="using:CommunityToolkit.WinUI.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:dev="using:DevWinUI"
      xmlns:local="using:AutoOS"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:models="using:AutoOS.Helpers.Device"
      xmlns:views="using:AutoOS.Views"
      mc:Ignorable="d">
    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Margin="36,24,0,0"
                   Style="{StaticResource TitleTextBlockStyle}"
                   Text="Bluetooth &amp; Devices" />
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto">
            <StackPanel Margin="{ThemeResource ContentPageMargin}"
                        Padding="{ThemeResource ContentPagePadding}"
                        dev:PanelAttach.ChildrenTransitions="Default">
                <dev:SettingsGroup Description="Toggle Services &amp; Drivers required for Bluetooth functionality."
                                   Header="Bluetooth">
                    <dev:SettingsGroup.HeaderIcon>
                        <FontIcon Foreground="{ThemeResource SystemAccentColor}"
                                  Glyph="&#xE702;" />
                    </dev:SettingsGroup.HeaderIcon>
                    <dev:SettingsGroup.Content>
                        <ToggleSwitch x:Name="Bluetooth"
                                      Toggled="Bluetooth_Toggled" />
                    </dev:SettingsGroup.Content>
                </dev:SettingsGroup>
                <StackPanel x:Name="BluetoothInfo"
                            Margin="4,8,4,0" />
                <ItemsRepeater x:Name="XhciRepeater"
                               Margin="0,0,0,28"
                               ItemsSource="{x:Bind XHCIs, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:DeviceInfo">
                            <StackPanel>
                                <dev:SettingsGroup Description="{x:Bind Location, Mode=OneWay}"
                                                   Header="{x:Bind FriendlyName, Mode=OneWay}">
                                    <dev:SettingsGroup.HeaderIcon>
                                        <ImageIcon Source="/Assets/Fluent/Devices.png" />
                                    </dev:SettingsGroup.HeaderIcon>
                                    <dev:SettingsGroup.Items>
                                        <dev:SettingsCard Description="Disabling IMOD fixes data loss when creating too many interrupts. Recommended to disable on high polling rate mice/keyboards."
                                                          Header="XHCI Interrupt Moderation (IMOD)">
                                            <StackPanel Orientation="Horizontal">
                                                <ToggleSwitch DataContext="{x:Bind}"
                                                              IsOn="{x:Bind IsActive, Mode=TwoWay}"
                                                              Toggled="IMOD_Toggled" />
                                            </StackPanel>
                                        </dev:SettingsCard>
                                    </dev:SettingsGroup.Items>
                                </dev:SettingsGroup>
                                <StackPanel x:Name="DevicesInfo"
                                            Margin="4,8,4,0" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

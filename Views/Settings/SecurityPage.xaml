<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="AutoOS.Views.Settings.SecurityPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:dev="using:DevWinUI"
      xmlns:local="using:AutoOS"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:views="using:AutoOS.Views"
      mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Margin="36,24,0,0"
                   Style="{StaticResource TitleTextBlockStyle}"
                   Text="Windows Security" />
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto">
            <StackPanel Margin="{ThemeResource ContentPageMargin}"
                        Padding="{ThemeResource ContentPagePadding}"
                        dev:PanelAttach.ChildrenTransitions="Default">
                <dev:SettingsGroup Description="Toggle Windows Defender and other security settings."
                                   Header="Windows Defender">
                    <dev:SettingsGroup.HeaderIcon>
                        <ImageIcon Source="/Assets/Fluent/Defender.png" />
                    </dev:SettingsGroup.HeaderIcon>
                    <dev:SettingsGroup.Content>
                        <ToggleSwitch x:Name="WindowsDefender"
                                      Toggled="WindowsDefender_Toggled" />
                    </dev:SettingsGroup.Content>
                    <dev:SettingsGroup.Items>
                        <dev:SettingsCard Description="Limits applications to standard user privileges until an administrator authorizes an elevation."
                                          Header="User Account Control (UAC)">
                            <ToggleSwitch x:Name="UAC"
                                          Toggled="UAC_Toggled" />
                        </dev:SettingsCard>
                        <dev:SettingsCard Description="Protection against malicious code execution in memory areas. Some anti-cheats require this to be enabled. Can't be disabled when secure boot is enabled."
                                          Header="Data Execution Prevention (DEP)">
                            <ToggleSwitch x:Name="DEP"
                                          Toggled="DEP_Toggled" />
                        </dev:SettingsCard>
                        <dev:SettingsCard Description="Enforces kernel-mode code integrity by using the hypervisor to block unsigned or untrusted drivers from loading. Some anti-cheats require this to be enabled."
                                          Header="Hypervisor Enforced Code Integrity (HVCI)">
                            <ToggleSwitch x:Name="MemoryIntegrity"
                                          Toggled="MemoryIntegrity_Toggled" />
                        </dev:SettingsCard>
                        <dev:SettingsCard Description="Uses hardware virtualization and the Windows hypervisor to create an isolated virtual environment that becomes the root of trust of the OS that assumes the kernel can be compromised."
                                          Header="Virtualization-based Security (VBS)">
                            <ToggleSwitch x:Name="VirtualizationBasedSecurity"
                                          Toggled="VirtualizationBasedSecurity_Toggled" />
                        </dev:SettingsCard>
                        <dev:SettingsCard Description="Patches to enable mitigation against CPU vulnerabilities. Increases performance especially on older Intel CPUs. Recommended to keep enabled on AMD CPUs."
                                          Header="Spectre &amp; Meltdown Mitigations">
                            <ToggleSwitch x:Name="SpectreMeltdown"
                                          Toggled="SpectreMeltdown_Toggled" />
                        </dev:SettingsCard>
                        <dev:SettingsCard Description="Process-level mitigations to enhance security."
                                          Header="Process Mitigations">
                            <ToggleSwitch x:Name="ProcessMitigations"
                                          Toggled="ProcessMitigations_Toggled" />
                        </dev:SettingsCard>
                    </dev:SettingsGroup.Items>
                </dev:SettingsGroup>
                <StackPanel x:Name="WindowsDefenderInfo"
                            Margin="4,8,4,28" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

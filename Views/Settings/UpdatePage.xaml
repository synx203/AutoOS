<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="AutoOS.Views.Settings.UpdatePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:dev="using:DevWinUI"
      xmlns:local="using:AutoOS"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:views="using:AutoOS.Views"
      mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Margin="36,24,0,0"
                   Style="{StaticResource TitleTextBlockStyle}"
                   Text="Windows Update" />
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto">
            <StackPanel Margin="{ThemeResource ContentPageMargin}"
                        Padding="{ThemeResource ContentPagePadding}"
                        dev:PanelAttach.ChildrenTransitions="Default">
                <dev:SettingsGroup Description="AutoOS supports installing Windows Updates without losing any tweaks. It is recommended to enable Windows Updates from time to time and install them through the Settings app."
                                   Header="Windows Updates">
                    <dev:SettingsGroup.HeaderIcon>
                        <ImageIcon Source="/Assets/Fluent/Update2.png" />
                    </dev:SettingsGroup.HeaderIcon>
                    <dev:SettingsGroup.Content>
                        <ToggleSwitch x:Name="WindowsUpdate"
                                      Toggled="Update_Toggled" />
                    </dev:SettingsGroup.Content>
                    <dev:SettingsGroup.Items>
                        <dev:SettingsCard Header="Target Version">
                            <ComboBox x:Name="TargetVersion"
                                      SelectionChanged="TargetVersion_SelectionChanged" />
                        </dev:SettingsCard>
                    </dev:SettingsGroup.Items>
                </dev:SettingsGroup>
                <StackPanel x:Name="WindowsUpdateInfo"
                            Margin="4,8,4,28" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>

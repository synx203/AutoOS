<?xml version="1.0" encoding="utf-8" ?>
<Page x:Class="AutoOS.Views.Settings.GraphicsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="using:CommunityToolkit.WinUI.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:dev="using:DevWinUI"
      xmlns:local="using:AutoOS"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:models="using:AutoOS.Helpers.GPU"
      xmlns:views="using:AutoOS.Views"
      mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TextBlock Margin="36,24,0,0"
                   Style="{StaticResource TitleTextBlockStyle}"
                   Text="Graphics Cards" />
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      VerticalScrollMode="Auto">
            <StackPanel Margin="{ThemeResource ContentPageMargin}"
                        Padding="{ThemeResource ContentPagePadding}"
                        dev:PanelAttach.ChildrenTransitions="Default">
                <ItemsRepeater x:Name="GpuRepeater"
                               ItemsSource="{x:Bind GPUs, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:GpuInfo">
                            <StackPanel>
                                <dev:SettingsGroup Description="{x:Bind CurrentVersion, Mode=OneWay}"
                                                   Header="{x:Bind DeviceName, Mode=OneWay}"
                                                   HeaderIcon="{x:Bind VendorId, Converter={StaticResource VendorIdToImageIconConverter}}">
                                    <dev:SettingsGroup.Content>
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="8">
                                            <dev:ProgressButton x:Name="ProgressButton"
                                                                Checked="ProgressButton_Checked"
                                                                CheckedContent="Checking for updates..."
                                                                Content="No updates available"
                                                                DataContext="{x:Bind}"
                                                                IsIndeterminate="True"
                                                                Loaded="ProgressButton_Loaded"
                                                                Style="{ThemeResource AccentProgressButtonStyle}" />
                                            <dev:ProgressButton CheckedContent="Uninstalling"
                                                                Content="Uninstall"
                                                                DataContext="{x:Bind}"
                                                                IsIndeterminate="True"
                                                                Visibility="Collapsed" />
                                        </StackPanel>
                                    </dev:SettingsGroup.Content>
                                    <dev:SettingsGroup.Items>
                                        <dev:SettingsCard Description="Disabling Dynamic Performance States (P-States) locks the GPU at its maximum clock frequency which increases temperatures and power consumption."
                                                          Header="Dynamic Performance States (P-States)"
                                                          Visibility="{x:Bind NVIDIA, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <ToggleSwitch DataContext="{x:Bind}"
                                                          IsOn="{x:Bind PStates, Mode=TwoWay}"
                                                          Toggled="PStates_Toggled" />
                                        </dev:SettingsCard>
                                        <dev:SettingsCard Description="Disabling HDCP breaks Netflix and other protected video streaming services."
                                                          Header="High-Bandwidth Digital Content Protection (HDCP)"
                                                          Visibility="{x:Bind NVIDIA, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <ToggleSwitch DataContext="{x:Bind}"
                                                          IsOn="{x:Bind HDCP, Mode=TwoWay}"
                                                          Toggled="HDCP_Toggled" />
                                        </dev:SettingsCard>
                                        <dev:SettingsCard Description="Enabling GPU System Processor (GSP) Firmware offloads driver tasks from the CPU to the GPU System Processor (GSP) for lower latency but can cause unexpected driver issues."
                                                          Header="GPU System Processor (GSP) Firmware"
                                                          Visibility="{x:Bind RTX, Converter={StaticResource BoolToVisibilityConverter}}">
                                            <ToggleSwitch DataContext="{x:Bind}"
                                                          IsOn="{x:Bind GspFirmware, Mode=TwoWay}"
                                                          Toggled="GspFirmware_Toggled" />
                                        </dev:SettingsCard>
                                        <dev:SettingsCard Description="Disabling HDMI/DP Audio prevents audio devices connected to the graphics card from showing up."
                                                          Header="High-Definition Multimedia Interface (HDMI)/DisplayPort (DP) Audio">
                                            <ToggleSwitch DataContext="{x:Bind}"
                                                          IsOn="{x:Bind HDMIDPAudio, Mode=TwoWay}"
                                                          Toggled="HDMIDPAudio_Toggled" />
                                        </dev:SettingsCard>

                                    </dev:SettingsGroup.Items>
                                </dev:SettingsGroup>
                                <StackPanel x:Name="GpuInfo"
                                            Margin="4,8,4,0" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
                <dev:SettingsGroup Description="Overclock your graphics card, remove power limits, set custom fan curves, and more."
                                   Header="MSI Afterburner">
                    <dev:SettingsGroup.HeaderIcon>
                        <ImageIcon Source="/Assets/Fluent/MsiAfterburner.png" />
                    </dev:SettingsGroup.HeaderIcon>
                    <dev:SettingsGroup.Content>
                        <Button HorizontalAlignment="Left"
                                Click="BrowseMsi_Click"
                                Content="Import profile"
                                Style="{ThemeResource AccentButtonStyle}" />
                    </dev:SettingsGroup.Content>
                    <dev:SettingsGroup.Items>
                        <dev:SettingsCard Header="Create an overclock"
                                          IsClickEnabled="False">
                            <Button Click="LaunchMsi_Click"
                                    Content="Launch" />
                        </dev:SettingsCard>
                    </dev:SettingsGroup.Items>
                </dev:SettingsGroup>
                <StackPanel x:Name="MsiAfterburnerInfo"
                            Margin="4,8,4,0" />
                <dev:SettingsGroup Description="Launch OBS Studio on startup and start the replay buffer."
                                   Header="OBS Studio">
                    <dev:SettingsGroup.HeaderIcon>
                        <ImageIcon Source="/Assets/Fluent/Obs.png" />
                    </dev:SettingsGroup.HeaderIcon>
                    <dev:SettingsGroup.Content>
                        <ToggleSwitch x:Name="OBS"
                                      Toggled="OBS_Toggled">
                        </ToggleSwitch>
                    </dev:SettingsGroup.Content>
                </dev:SettingsGroup>
                <StackPanel x:Name="ObsStudioInfo"
                            Margin="4,8,4,28" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
    <Page.Resources>
        <models:VendorIdToImageIconConverter x:Key="VendorIdToImageIconConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>
</Page>
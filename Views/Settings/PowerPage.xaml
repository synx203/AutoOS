<Page x:Class="AutoOS.Views.Settings.PowerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:CommunityToolkit.WinUI.Controls"
      xmlns:converters="using:CommunityToolkit.WinUI.Converters"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:dev="using:DevWinUI"
      xmlns:local="using:AutoOS.Views.Settings.Power"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      mc:Ignorable="d">
    <Page.Resources>
        <DataTemplate x:Key="SubgroupTemplate"
                      x:DataType="local:PowerModelItem">
            <TreeViewItem IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                          ItemsSource="{x:Bind Settings}"
                          Visibility="{x:Bind IsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <controls:DataRow>
                    <TextBlock />
                    <TextBlock Margin="-24,0,0,0"
                               FontWeight="{x:Bind FontWeight, Mode=OneWay}"
                               Text="{x:Bind Name, Mode=OneWay}" />
                    <TextBlock />
                    <TextBlock />
                </controls:DataRow>
            </TreeViewItem>
        </DataTemplate>
        <DataTemplate x:Key="SettingTemplate"
                      x:DataType="local:PowerModelItem">
            <TreeViewItem Visibility="{x:Bind IsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <controls:DataRow>
                    <TextBlock />
                    <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                               ToolTipService.ToolTip="{x:Bind Description, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind AcValueIndex, Mode=OneWay}"
                               ToolTipService.ToolTip="{x:Bind FriendlyAcValue, Mode=OneWay}" />
                    <TextBlock Text="{x:Bind DcValueIndex, Mode=OneWay}"
                               ToolTipService.ToolTip="{x:Bind FriendlyDcValue, Mode=OneWay}" />
                </controls:DataRow>
            </TreeViewItem>
        </DataTemplate>
        <local:PowerItemTemplateSelector x:Key="PowerItemTemplateSelector"
                                         SettingTemplate="{StaticResource SettingTemplate}"
                                         SubgroupTemplate="{StaticResource SubgroupTemplate}" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

        <DataTemplate x:Key="PowerPlanTemplate"
                      x:DataType="local:PowerPlan">
            <TextBlock Text="{x:Bind Name}"
                       TextTrimming="CharacterEllipsis"
                       TextWrapping="NoWrap"
                       ToolTipService.ToolTip="{x:Bind Description}">
            </TextBlock>
        </DataTemplate>
        <DataTemplate x:Key="CompareSubgroupTemplate"
                      x:DataType="local:PowerCompareModelItem">
            <TreeViewItem IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}"
                          ItemsSource="{x:Bind Settings}"
                          Visibility="{x:Bind IsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <controls:DataRow>
                    <TextBlock />
                    <TextBlock Margin="-24,0,0,0"
                               FontWeight="{x:Bind FontWeight, Mode=OneWay}"
                               Text="{x:Bind Name, Mode=OneWay}" />
                    <TextBlock />
                    <TextBlock />
                    <TextBlock />
                    <TextBlock />
                </controls:DataRow>
            </TreeViewItem>
        </DataTemplate>
        <DataTemplate x:Key="CompareSettingTemplate"
                      x:DataType="local:PowerCompareModelItem">
            <TreeViewItem Visibility="{x:Bind IsVisible, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}">
                <controls:DataRow>
                    <TextBlock />
                    <TextBlock Text="{x:Bind Name, Mode=OneWay}"
                               ToolTipService.ToolTip="{x:Bind Description, Mode=OneWay}" />
                    <Grid CornerRadius="4">
                        <Border Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                                CornerRadius="4"
                                Visibility="{x:Bind IsAcDifferent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Margin="4,0"
                                   Text="{x:Bind Plan1AcValue, Mode=OneWay}"
                                   ToolTipService.ToolTip="{x:Bind Plan1AcFriendlyValue, Mode=OneWay}" />
                    </Grid>
                    <Grid CornerRadius="4">
                        <Border Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                                CornerRadius="4"
                                Visibility="{x:Bind IsDcDifferent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Margin="4,0"
                                   Text="{x:Bind Plan1DcValue, Mode=OneWay}"
                                   ToolTipService.ToolTip="{x:Bind Plan1DcFriendlyValue, Mode=OneWay}" />
                    </Grid>
                    <Grid CornerRadius="4">
                        <Border Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                                CornerRadius="4"
                                Visibility="{x:Bind IsAcDifferent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Margin="4,0"
                                   Text="{x:Bind Plan2AcValue, Mode=OneWay}"
                                   ToolTipService.ToolTip="{x:Bind Plan2AcFriendlyValue, Mode=OneWay}" />
                    </Grid>
                    <Grid CornerRadius="4">
                        <Border Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                                CornerRadius="4"
                                Visibility="{x:Bind IsDcDifferent, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <TextBlock Margin="4,0"
                                   Text="{x:Bind Plan2DcValue, Mode=OneWay}"
                                   ToolTipService.ToolTip="{x:Bind Plan2DcFriendlyValue, Mode=OneWay}" />
                    </Grid>
                </controls:DataRow>
            </TreeViewItem>
        </DataTemplate>
        <local:PowerCompareItemTemplateSelector x:Key="PowerCompareItemTemplateSelector"
                                                SettingTemplate="{StaticResource CompareSettingTemplate}"
                                                SubgroupTemplate="{StaticResource CompareSubgroupTemplate}" />
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0"
                    Margin="36,24,36,0">
            <!--  Title  -->
            <TextBlock Style="{StaticResource TitleTextBlockStyle}"
                       Text="Energy &amp; Power" />
            <Grid Margin="0,48,0,8"
                  HorizontalAlignment="Stretch"
                  RowSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <!--  Search  -->
                <dev:TextBox x:Name="Search"
                             Grid.Row="0"
                             Grid.Column="0"
                             Grid.ColumnSpan="6"
                             PlaceholderText="Search..."
                             TextChanged="SearchBox_TextChanged">
                    <dev:TextBox.Content>
                        <Button Content="&#xE71E;" />
                    </dev:TextBox.Content>
                </dev:TextBox>
                <!--  Power plan  -->
                <ComboBox x:Name="PowerPlanComboBox"
                          Grid.Row="1"
                          Grid.Column="0"
                          Margin="0,0,8,0"
                          HorizontalAlignment="Stretch"
                          ItemTemplate="{StaticResource PowerPlanTemplate}"
                          SelectionChanged="PowerPlanComboBox_SelectionChanged" />
                <!--  Compare power plan  -->
                <ComboBox x:Name="ComparePowerPlanComboBox"
                          Grid.Row="1"
                          Grid.Column="1"
                          Margin="0,0,8,0"
                          HorizontalAlignment="Stretch"
                          ItemTemplate="{StaticResource PowerPlanTemplate}"
                          SelectionChanged="ComparePowerPlanComboBox_SelectionChanged" />
                <!--  Edit  -->
                <Button x:Name="Edit"
                        Grid.Row="1"
                        Grid.Column="2"
                        Margin="0,0,8,0"
                        VerticalAlignment="Stretch"
                        Click="Edit_Click">
                    <StackPanel VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <FontIcon Margin="0,0,8,0"
                                  FontSize="14"
                                  Glyph="&#xE70F;" />
                        <TextBlock Text="Edit" />
                    </StackPanel>
                </Button>
                <!--  Delete  -->
                <Button x:Name="Delete"
                        Grid.Row="1"
                        Grid.Column="3"
                        Margin="0,0,8,0"
                        VerticalAlignment="Stretch"
                        Click="Delete_Click">
                    <StackPanel VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <FontIcon Margin="0,0,8,0"
                                  FontSize="14"
                                  Glyph="&#xE74D;" />
                        <TextBlock Text="Delete" />
                    </StackPanel>
                </Button>
                <!--  Export  -->
                <Button x:Name="Export"
                        Grid.Row="1"
                        Grid.Column="4"
                        Margin="0,0,8,0"
                        Click="Export_Click">
                    <StackPanel VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <FontIcon Margin="0,0,8,0"
                                  FontSize="14"
                                  Glyph="&#xEDE1;" />
                        <TextBlock Text="Export" />
                    </StackPanel>
                </Button>
                <!--  Import  -->
                <Button x:Name="Import"
                        Grid.Row="1"
                        Grid.Column="5"
                        Click="Import_Click">
                    <StackPanel VerticalAlignment="Center"
                                Orientation="Horizontal">
                        <FontIcon Margin="0,0,8,0"
                                  FontSize="14"
                                  Glyph="&#xE8B5;" />
                        <TextBlock Text="Import" />
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>
        <!--  Background  -->
        <Border Grid.Row="1"
                Margin="36,0,36,36"
                Padding="4,6"
                VerticalAlignment="Top"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource ControlCornerRadius}">
            <Grid>
                <!--  Active TreeView  -->
                <controls:HeaderedTreeView x:Name="ActiveTreeView"
                                           AllowDrop="False"
                                           CanDrag="False"
                                           CanDragItems="False"
                                           ItemInvoked="TreeView_ItemInvoked"
                                           ItemTemplateSelector="{StaticResource PowerItemTemplateSelector}"
                                           ItemsSource="{x:Bind Subgroups}"
                                           SelectionMode="None">
                    <!--  Headers  -->
                    <controls:HeaderedTreeView.Header>
                        <controls:DataTable ColumnSpacing="8">
                            <controls:DataColumn Content=""
                                                 DesiredWidth="Auto" />
                            <controls:DataColumn Margin="-48,0,48,0"
                                                 Content="Name"
                                                 DesiredWidth="*" />
                            <controls:DataColumn MinWidth="85"
                                                 Content="Ac"
                                                 DesiredWidth="85" />
                            <controls:DataColumn MinWidth="110"
                                                 Content="Dc"
                                                 DesiredWidth="110" />
                        </controls:DataTable>
                    </controls:HeaderedTreeView.Header>
                </controls:HeaderedTreeView>
                <!--  Compare TreeView  -->
                <controls:HeaderedTreeView x:Name="CompareTreeView"
                                           AllowDrop="False"
                                           CanDrag="False"
                                           CanDragItems="False"
                                           ItemInvoked="CompareTreeView_ItemInvoked"
                                           ItemTemplateSelector="{StaticResource PowerCompareItemTemplateSelector}"
                                           ItemsSource="{x:Bind CompareSubgroups}"
                                           SelectionMode="None">
                    <controls:HeaderedTreeView.Header>
                        <controls:DataTable ColumnSpacing="8">
                            <controls:DataColumn Content=""
                                                 DesiredWidth="Auto" />
                            <controls:DataColumn Margin="-48,0,48,0"
                                                 Content="Name"
                                                 DesiredWidth="*" />
                            <controls:DataColumn MinWidth="85"
                                                 Content="1 (AC)"
                                                 DesiredWidth="85" />
                            <controls:DataColumn MinWidth="85"
                                                 Content="1 (DC)"
                                                 DesiredWidth="85" />
                            <controls:DataColumn MinWidth="85"
                                                 Content="2 (AC)"
                                                 DesiredWidth="85" />
                            <controls:DataColumn MinWidth="130"
                                                 Content="2 (DC)"
                                                 DesiredWidth="130" />
                        </controls:DataTable>
                    </controls:HeaderedTreeView.Header>
                </controls:HeaderedTreeView>
            </Grid>
        </Border>
    </Grid>
</Page>

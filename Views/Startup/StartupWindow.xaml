<?xml version="1.0" encoding="utf-8" ?>
<Window x:Class="AutoOS.Views.Startup.StartupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:dev="using:DevWinUI"
        xmlns:local="using:AutoOS"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition />
        </Grid.RowDefinitions>
        <TitleBar x:Name="AppTitleBar"
                  Title="{x:Bind TitleBarName}"
                  IsBackButtonVisible="False"
                  IsPaneToggleButtonVisible="False"
                  Subtitle="{x:Bind dev:ProcessInfoHelper.VersionWithPrefix}">
            <TitleBar.LeftHeader>
                <ImageIcon Width="16"
                           Height="16"
                           Margin="14,0,2,0"
                           PointerPressed="AppIcon_PointerPressed"
                           Source="/Assets/AppIcon.png" />
            </TitleBar.LeftHeader>
        </TitleBar>
        <StackPanel Grid.Row="1"
                    Margin="14,0,14,0"
                    Spacing="12">
            <TextBlock x:Name="StatusText"
                       Margin="0,12,0,0" />
            <ProgressBar x:Name="ProgressBar" />
        </StackPanel>
    </Grid>
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>
</Window>